<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1A1B2E"
                android:centerColor="#16182D"
                android:endColor="#0D0F1A"
                android:angle="315"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1E2040"
                android:centerColor="#161830"
                android:endColor="#0F1020"
                android:angle="315"
                android:type="linear" />
            <corners android:radius="23dp" />
        </shape>
    </item>
</layer-list>
